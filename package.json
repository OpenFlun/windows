    "bin",
    "index.d.ts",
    "index.js",
    "sevWin.js",
    "copy-files.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "preferGlobal": true,
  "dependencies": {
    "xml": "1.0.1",
    "yargs": "^18.0.0"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenFlun/windows.git"
  },
  "homepage": "https://www.npmjs.com/package/@flun/windows#readme",
