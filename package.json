{
  "name": "@flun/windows",
  "version": "3.0.1",
  "description": "支持 Windows 服务、事件日志、UAC 以及多种与操作系统交互的辅助方法",
  "keywords": [
    "windows",
    "service",
    "daemon",
    "logging",
    "event",
    "event logging",
    "elevate",
    "sudo",
    "task"
  ],
  "author": "flun <cn@flun.top>",
